# URL pública del frontend que se incluye en los enlaces de invitación
APP_PUBLIC_URL=http://localhost:3000

# ── SMTP (opcional) ──
# Si defines SMTP_HOST se activa el envío de emails con nodemailer.
# Ejemplo con Gmail (usa una "app password"):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=tu@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#   SMTP_FROM="Invoice Gen <tu@gmail.com>"
#   SMTP_REPLY_TO=tu@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=
